{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "altalune-public",
  "main": "index.js",
  "compatibility_date": "2026-06-30",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "altalune-db",
      "database_id": "83adbf08-ef77-48ad-93e7-7b7f8b28ffed"
    }
  ]
}
